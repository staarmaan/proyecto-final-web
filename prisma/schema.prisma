enum ColorPiel {
  PIEL
  AMARILLO
  ROJO
  PURPURA
  PRIETO
}

enum ColorTallo {
  VERDE
  AZUL
  NARANJA
  AMARILLO
  ROJO
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Rabanoide {
  id             Int        @id @default(autoincrement())
  colorpiel      ColorPiel  @default(PIEL)
  colortallo     ColorTallo @default(VERDE)
  hiperactividad Decimal    @default(0.5)
  defensa        Decimal    @default(0.5)
  regeneracion   Decimal    @default(0.5)
  damage         Decimal    @default(0.5)
  velocidad      Decimal    @default(0.5)
  saltoaltura    Decimal    @default(0.5)
  inteligencia   Decimal    @default(0.5)
  autocombustion Decimal    @default(0.5)
}

model Item {
  id     Int @id @default(autoincrement())
  itemId Int
}

